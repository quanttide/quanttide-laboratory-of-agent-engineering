#!/usr/bin/env bash
# simulate — 展示「契约—注册」模型
#
# 契约（contract/）定义行为规则，各 Agent 通过注册（registrations/）引用契约。
# 不修改真实环境。

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONTRACT_DIR="$SCRIPT_DIR/contract"
REG_DIR="$SCRIPT_DIR/registrations"

info()   { printf "\033[36m%s\033[0m\n" "$*"; }
ok()     { printf "\033[32m  ✓ %s\033[0m\n" "$*"; }
header() { printf "\n\033[1;33m%s\033[0m\n" "$*"; }

# 契约文件及其注册方式
DECLARATIONS=(
  "AGENTS.md:Zed:registrations/zed/AGENTS.md  → symlink contract/AGENTS.md"
  "ponytail.mjs:OpenCode:registrations/opencode/opencode.json  → plugin reference"
  "skills/ponytail/SKILL.md:Hermes:registrations/hermes/skills/ponytail/SKILL.md  → file copy"
)

show() {
  header "契约（contract/）"
  for entry in "${DECLARATIONS[@]}"; do
    local file="${entry%%:*}"
    local agent="${entry#*:}"; agent="${agent%%:*}"
    local reg="${entry##*:}"
    local path="$CONTRACT_DIR/$file"
    local lines=$(wc -l < "$path")

    info "$file"
    echo "  注册: $reg"
    echo "  格式: ${file##*.}"
    echo "  行数: $lines 行"
    echo "  前 3 行:"
    head -3 "$path" | sed 's/^/    /'
    echo ""
  done

  header "注册示例（registrations/）"
  echo "  Zed:       registrations/zed/AGENTS.md  → symlink 指向 contract/AGENTS.md"
  echo "  OpenCode:  registrations/opencode/opencode.json  → plugin 引用 contract/ponytail.mjs"
  echo "  Hermes:    registrations/hermes/skills/ponytail/SKILL.md  → 从 contract 复制"
  echo ""

  ok "契约在一处定义，各 Agent 各自注册引用。"
}

main() {
  show
}

main "$@"
